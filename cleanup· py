        for item in self.project_path.iterdir():
            if not item.is_dir():
                continue
            if item.name in VENV_DIRS:
                dir_size = 0
                file_count = 0
                try:
                    for root, dirs, files in os.walk(item):
                        for f in files:
                            try:
                                dir_size += (Path(root) / f).stat().st_size
                                file_count += 1
                            except:
                                pass
                except:
                    pass

                self.results['venv_dirs'].append({
                    "dir": item.name,
                    "path": str(item),
                    "size": dir_size,
                    "size_human": self._human_size(dir_size),
                    "file_count": file_count,
                })
                self.results['summary']['total_space_reclaimable'] += dir_size
                self.results['summary']['total_dirs_to_remove'] += 1

        # نمایش
        if self.results['venv_dirs']:
