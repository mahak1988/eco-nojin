                print(f"    {Color.RED}✗{Color.RESET} {item['size_human']:>12}  {item['dir']}/  ({item['file_count']} فایل)")
        else:
            print(f"  {Color.GREEN}✓ پوشه محیط مجازی یافت نشد.{Color.RESET}")

    # ============================================================
    #  فاز ۵: شناسایی فایل‌های باینری و دیتابیس
    # ============================================================
    def find_binary_and_db_files(self):
        print(f"\n{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}  ۵. فایل‌های باینری و دیتابیس{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")

        for root, dirs, files in os.walk(self.project_path):
            dirs[:] = [d for d in dirs if not self._should_skip_dir(d)
                       and d not in BACKUP_DIRS and d not in VENV_DIRS]

            for f in files:
                file_path = Path(root) / f
                ext = file_path.suffix.lower()

                try:
                    size = file_path.stat().st_size
                except:
                    continue

                rel_path = str(file_path.relative_to(self.project_path))

                if ext in BINARY_EXTENSIONS:
                    self.results['binary_files'].append({
                        "file": rel_path,
                        "size": size,
                        "size_human": self._human_size(size),
                        "extension": ext,
                    })
                    self.results['summary']['total_space_reclaimable'] += size
                    self.results['summary']['total_files_to_remove'] += 1

                elif ext in DB_EXTENSIONS:
                    self.results['db_files'].append({
                        "file": rel_path,
                        "size": size,
                        "size_human": self._human_size(size),
                    })
                    self.results['summary']['total_space_reclaimable'] += size
                    self.results['summary']['total_files_to_remove'] += 1

        # نمایش
        if self.results['binary_files']:
            print(f"  {Color.YELLOW}فایل‌های باینری: {len(self.results['binary_files'])}{Color.RESET}")
            for item in sorted(self.results['binary_files'], key=lambda x: x['size'], reverse=True)[:5]:
                print(f"    {Color.RED}✗{Color.RESET} {item['size_human']:>12}  {item['file']}")

        if self.results['db_files']:
            print(f"\n  {Color.YELLOW}فایل‌های دیتابیس: {len(self.results['db_files'])}{Color.RESET}")
            for item in self.results['db_files']:
                print(f"    {Color.RED}✗{Color.RESET} {item['size_human']:>12}  {item['file']}")

        if not self.results['binary_files'] and not self.results['db_files']:
            print(f"  {Color.GREEN}✓ فایل باینری/دیتابیسی یافت نشد.{Color.RESET}")

    # ============================================================
    #  فاز ۶: شناسایی فایل‌های تکراری (با هش)
    # ============================================================
    def find_duplicate_files(self):
        print(f"\n{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}  ۶. فایل‌های تکراری{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")

        # فقط فایل‌های بزرگتر از DUPLICATE_MIN_SIZE رو بررسی می‌کنیم
        size_map = defaultdict(list)

        for root, dirs, files in os.walk(self.project_path):
            dirs[:] = [d for d in dirs if not self._should_skip_dir(d)
                       and d not in BACKUP_DIRS and d not in VENV_DIRS]

            for f in files:
                file_path = Path(root) / f
                try:
                    size = file_path.stat().st_size
                except:
                    continue
                if size >= DUPLICATE_MIN_SIZE:
                    size_map[size].append(str(file_path))

        # فقط فایل‌هایی با حجم مشابه رو هش می‌کنیم
        duplicates_found = []
        for size, paths in size_map.items():
            if len(paths) < 2:
                continue
            hash_map = defaultdict(list)
            for path in paths:
                try:
                    h = hashlib.md5()
                    with open(path, 'rb') as f:
                        for chunk in iter(lambda: f.read(8192), b''):
                            h.update(chunk)
                    hash_map[h.hexdigest()].append(path)
                except:
                    pass

            for h, dup_paths in hash_map.items():
                if len(dup_paths) >= 2:
                    duplicates_found.append({
                        "hash": h[:8],
                        "size": size,
                        "size_human": self._human_size(size),
                        "files": dup_paths,
                        "count": len(dup_paths),
                    })

        self.results['duplicate_files'] = duplicates_found

        # نمایش
        if duplicates_found:
            print(f"  {Color.YELLOW}تعداد گروه‌های تکراری: {len(duplicates_found)}{Color.RESET}")
            for dup in duplicates_found[:5]:
                print(f"    {Color.MAGENTA}⧉{Color.RESET} {dup['size_human']:>10} × {dup['count']}  (hash: {dup['hash']})")
                for p in dup['files'][:2]:
                    rel = str(Path(p).relative_to(self.project_path))
                    print(f"        {Color.GRAY}{rel}{Color.RESET}")
                if len(dup['files']) > 2:
                    print(f"        {Color.GRAY}... و {len(dup['files'])-2} مورد دیگر{Color.RESET}")
        else:
            print(f"  {Color.GREEN}✓ فایل تکراری یافت نشد.{Color.RESET}")

    # ============================================================
    #  فاز ۷: فایل‌های خالی و قدیمی و بزرگ
    # ============================================================
    def find_misc_files(self):
        print(f"\n{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}  ۷. فایل‌های خالی، قدیمی و بزرگ{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")

        old_threshold = datetime.now().timestamp() - (OLD_FILE_DAYS * 86400)
        large_threshold = LARGE_FILE_MB * 1024 * 1024

        for root, dirs, files in os.walk(self.project_path):
            dirs[:] = [d for d in dirs if not self._should_skip_dir(d)
                       and d not in BACKUP_DIRS and d not in VENV_DIRS]

            for f in files:
                file_path = Path(root) / f
                try:
                    stat = file_path.stat()
                except:
                    continue

                rel_path = str(file_path.relative_to(self.project_path))

                # فایل خالی
                if stat.st_size == 0:
                    self.results['empty_files'].append({"file": rel_path})

                # فایل قدیمی
                elif stat.st_mtime < old_threshold:
                    mtime = datetime.fromtimestamp(stat.st_mtime).strftime('%Y-%m-%d')
                    self.results['old_files'].append({
                        "file": rel_path,
                        "last_modified": mtime,
                        "days_old": (datetime.now().timestamp() - stat.st_mtime) // 86400,
                    })

                # فایل بزرگ
                if stat.st_size >= large_threshold:
                    self.results['large_files'].append({
                        "file": rel_path,
                        "size": stat.st_size,
                        "size_human": self._human_size(stat.st_size),
                    })

        # نمایش
        print(f"  {Color.YELLOW}فایل‌های خالی:{Color.RESET} {len(self.results['empty_files'])}")
        if self.results['empty_files']:
            for item in self.results['empty_files'][:5]:
                print(f"    {Color.GRAY}∅ {item['file']}{Color.RESET}")

        print(f"\n  {Color.YELLOW}فایل‌های قدیمی (>{OLD_FILE_DAYS} روز):{Color.RESET} {len(self.results['old_files'])}")
        if self.results['old_files']:
            for item in sorted(self.results['old_files'], key=lambda x: x['days_old'], reverse=True)[:5]:
                print(f"    {Color.GRAY}⏰ {item['days_old']:.0f} روز  {item['last_modified']}  {item['file']}{Color.RESET}")

        print(f"\n  {Color.YELLOW}فایل‌های بزرگ (>{LARGE_FILE_MB}MB):{Color.RESET} {len(self.results['large_files'])}")
        if self.results['large_files']:
            for item in sorted(self.results['large_files'], key=lambda x: x['size'], reverse=True)[:5]:
                print(f"    {Color.BLUE}📦 {item['size_human']:>10}  {item['file']}{Color.RESET}")

    # ============================================================
    #  فاز ۸: بررسی .gitignore
    # ============================================================
    def check_gitignore(self):
        print(f"\n{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}  ۸. بررسی .gitignore{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")

        gitignore_path = self.project_path / '.gitignore'
        if not gitignore_path.exists():
            self.results['gitignore_issues'].append({
                "issue": "فایل .gitignore وجود ندارد!",
                "severity": "HIGH",
            })
            print(f"  {Color.RED}✗ فایل .gitignore وجود ندارد!{Color.RESET}")
            return

        content = gitignore_path.read_text(encoding='utf-8', errors='ignore')

        # الگوهایی که باید در .gitignore باشن
        required_patterns = {
            'node_modules': r'node_modules',
            '.env': r'^\.env$|^\.env\.',
            '__pycache__': r'__pycache__',
            '.venv': r'\.venv|venv',
            'dist': r'^dist/?$|^build/?$',
            '.pnpm-store': r'\.pnpm-store',
            '*.db': r'\*\.db|\*\.sqlite',
            '*.log': r'\*\.log',
            '.DS_Store': r'\.DS_Store',
        }

        for name, pattern in required_patterns.items():
            if not re.search(pattern, content, re.MULTILINE):
                self.results['gitignore_issues'].append({
                    "issue": f"الگوی '{name}' در .gitignore نیست",
                    "severity": "MEDIUM",
                    "pattern": name,
                })

        # نمایش
        if self.results['gitignore_issues']:
            print(f"  {Color.YELLOW}مشکلات: {len(self.results['gitignore_issues'])}{Color.RESET}")
            for issue in self.results['gitignore_issues']:
                print(f"    {Color.YELLOW}⚠{Color.RESET} {issue['issue']}")
        else:
            print(f"  {Color.GREEN}✓ .gitignore کامل است.{Color.RESET}")

    # ============================================================
    #  اجرای تغییرات (وقتی --execute فعال است)
    # ============================================================
    def execute_changes(self):
        print(f"\n{Color.MAGENTA}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}  اجرای تغییرات{' (Dry Run)' if self.dry_run else ''}{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}{'='*60}{Color.RESET}")

        if self.dry_run:
            print(f"  {Color.YELLOW}حالت Dry-Run فعال است — هیچ تغییری اعمال نمی‌شود.{Color.RESET}")
            print(f"  {Color.GRAY}برای اجرای واقعی از --execute استفاده کنید.{Color.RESET}")
            return

        # ۱. حذف فایل‌های غیرضروری
        if self.results['junk_files']:
            print(f"\n  {Color.YELLOW}حذف فایل‌های غیرضروری...{Color.RESET}")
            for item in self.results['junk_files']:
                if self._confirm(f"حذف '{item['file']}'؟"):
                    try:
                        Path(item['path']).unlink()
                        self.deleted_count += 1
                        print(f"    {Color.GREEN}✓ حذف شد:{Color.RESET} {item['file']}")
                    except Exception as e:
                        self.failed_count += 1
                        print(f"    {Color.RED}✗ خطا:{Color.RESET} {item['file']} — {e}")

        # ۲. انتقال اسکریپت‌ها
        if self.results['scripts_to_move']:
            print(f"\n  {Color.YELLOW}انتقال اسکریپت‌ها به scripts/...{Color.RESET}")
            scripts_dir = self.project_path / 'scripts'
            scripts_dir.mkdir(exist_ok=True)
            for item in self.results['scripts_to_move']:
                if self._confirm(f"انتقال '{item['file']}'؟"):
                    try:
                        src = Path(item['path'])
                        dst = Path(item['destination'])
                        src.rename(dst)
                        self.moved_count += 1
                        print(f"    {Color.GREEN}✓ منتقل شد:{Color.RESET} {item['file']}")
                    except Exception as e:
                        self.failed_count += 1
                        print(f"    {Color.RED}✗ خطا:{Color.RESET} {item['file']} — {e}")

        # ۳. حذف پوشه‌های پشتیبان
        if self.results['backup_dirs']:
            print(f"\n  {Color.YELLOW}حذف پوشه‌های پشتیبان...{Color.RESET}")
            for item in self.results['backup_dirs']:
                if self._confirm(f"حذف پوشه '{item['dir']}' ({item['size_human']})؟"):
                    try:
                        import shutil
                        shutil.rmtree(item['path'])
                        self.deleted_count += 1
                        print(f"    {Color.GREEN}✓ حذف شد:{Color.RESET} {item['dir']}/")
                    except Exception as e:
                        self.failed_count += 1
                        print(f"    {Color.RED}✗ خطا:{Color.RESET} {item['dir']} — {e}")

    # ============================================================
    #  تولید گزارش
    # ============================================================
    def generate_summary(self):
        print(f"\n{Color.MAGENTA}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}  خلاصه نهایی{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}{'='*60}{Color.RESET}")

        s = self.results['summary']
        print(f"  {Color.CYAN}فایل‌های قابل حذف:{Color.RESET} {s['total_files_to_remove']}")
        print(f"  {Color.CYAN}فایل‌های قابل انتقال:{Color.RESET} {s['total_files_to_move']}")
        print(f"  {Color.CYAN}پوشه‌های قابل حذف:{Color.RESET} {s['total_dirs_to_remove']}")
        print(f"  {Color.CYAN}فضای قابل بازیابی:{Color.RESET} {self._human_size(s['total_space_reclaimable'])}")

        if not self.dry_run:
            print(f"\n  {Color.GREEN}✓ فایل‌های حذف شده:{Color.RESET} {self.deleted_count}")
            print(f"  {Color.GREEN}✓ فایل‌های منتقل شده:{Color.RESET} {self.moved_count}")
            if self.failed_count:
                print(f"  {Color.RED}✗ عملیات ناموفق:{Color.RESET} {self.failed_count}")

    # ============================================================
    #  ذخیره گزارش JSON
    # ============================================================
    def save_report(self):
        reports_dir = self.project_path / 'analysis_reports'
        reports_dir.mkdir(exist_ok=True)

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        report_path = reports_dir / f"cleanup_report_{timestamp}.json"

        with open(report_path, 'w', encoding='utf-8') as f:
            json.dump(self.results, f, ensure_ascii=False, indent=2)

        print(f"\n  {Color.GREEN}✓ گزارش ذخیره شد:{Color.RESET} {report_path}")
        return report_path

    # ============================================================
    #  اجرای کامل
    # ============================================================
    def run(self):
        print(f"\n{Color.MAGENTA}{Color.BOLD}{'╔' + '═'*58 + '╗'}{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}║  🧹 Cleanup Script v1.0.0 - پاکسازی پروژه{' ' * 12}║{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}║  مسیر: {str(self.project_path):<51}║{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}║  حالت: {'Dry-Run (بدون تغییر)' if self.dry_run else 'EXECUTE (با تغییر واقعی)':<43}║{Color.RESET}")
        print(f"{Color.MAGENTA}{Color.BOLD}{'╚' + '═'*58 + '╝'}{Color.RESET}")

        if not self.project_path.exists():
            print(f"{Color.RED}❌ خطا: مسیر پروژه وجود ندارد!{Color.RESET}")
            return False

        self.find_junk_files()
        self.find_scripts_to_move()
        self.find_backup_dirs()
        self.find_venv_dirs()
        self.find_binary_and_db_files()
        self.find_duplicate_files()
        self.find_misc_files()
        self.check_gitignore()
        self.execute_changes()
        self.generate_summary()
        self.save_report()

        print(f"\n{Color.GREEN}{Color.BOLD}✓ پاکسازی کامل شد!{Color.RESET}\n")
        return True


# ============================================================
#  نقطه ورود
# ============================================================
def main():
    Color.enable_windows()

    default_path = r"D:\econojin.com"

    parser = argparse.ArgumentParser(
        description='پاکسازی خودکار پروژه - Cleanup Script v1.0.0',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
مثال‌ها:
  python cleanup.py                                  # فقط گزارش (dry-run)
  python cleanup.py --execute                        # اجرا با تأیید هر مورد
  python cleanup.py --execute --force                # اجرا بدون تأیید
  python cleanup.py "D:\\my-project" --execute       # مسیر دلخواه
  python cleanup.py --no-color                       # بدون رنگ

گزارش در analysis_reports/cleanup_report_*.json ذخیره می‌شود.
        """
    )
    parser.add_argument('path', nargs='?', default=default_path,
                        help=f'مسیر پروژه (پیش‌فرض: {default_path})')
    parser.add_argument('--execute', action='store_true',
                        help='اجرای واقعی تغییرات (پیش‌فرض: dry-run)')
    parser.add_argument('--force', action='store_true',
                        help='بدون تأیید برای هر مورد')
    parser.add_argument('--no-color', action='store_true',
                        help='غیرفعال کردن رنگ')

    args = parser.parse_args()

    if args.no_color:
        Color.disable()

    cleaner = ProjectCleaner(
        project_path=args.path,
        dry_run=not args.execute,
        force=args.force,
    )
    success = cleaner.run()

    if not success:
        sys.exit(1)


if __name__ == '__main__':
    main()
