# ============================================================
#  کلاس اصلی Cleanup
# ============================================================
class ProjectCleaner:
    def __init__(self, project_path: str, dry_run: bool = True, force: bool = False):
        self.project_path = Path(project_path).resolve()
        self.dry_run = dry_run
        self.force = force

        self.results = {
            "meta": {
                "project_path": str(self.project_path),
                "executed_at": datetime.now().isoformat(),
                "mode": "dry-run" if dry_run else "execute",
                "platform": platform.system(),
            },
            "junk_files": [],
            "scripts_to_move": [],
            "backup_dirs": [],
            "venv_dirs": [],
            "binary_files": [],
            "db_files": [],
            "duplicate_files": [],
            "empty_files": [],
            "old_files": [],
            "large_files": [],
            "gitignore_issues": [],
            "summary": {
                "total_space_reclaimable": 0,
                "total_files_to_remove": 0,
                "total_files_to_move": 0,
                "total_dirs_to_remove": 0,
            },
        }

        self.deleted_count = 0
        self.moved_count = 0
        self.failed_count = 0

    # ----------------------------------------------------------
    def _should_skip_dir(self, dir_name: str) -> bool:
        return dir_name in SKIP_DIRS

    def _human_size(self, size_bytes: int) -> str:
        for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
            if size_bytes < 1024:
                return f"{size_bytes:.2f} {unit}"
            size_bytes /= 1024
        return f"{size_bytes:.2f} PB"

    def _confirm(self, message: str) -> bool:
        """تأیید کاربر برای انجام عملیات."""
        if self.force:
            return True
        response = input(f"  {Color.YELLOW}{message} (y/N): {Color.RESET}").strip().lower()
        return response in ['y', 'yes', 'n', 'بله']

    def _matches_any_pattern(self, name: str, patterns: list) -> bool:
        for pattern in patterns:
            if re.match(pattern, name, re.IGNORECASE):
                return True
        return False

    # ============================================================
    #  فاز ۱: شناسایی فایل‌های غیرضروری ریشه‌ای
    # ============================================================
    def find_junk_files(self):
        print(f"\n{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}  ۱. فایل‌های غیرضروری ریشه‌ای{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")

        # فایل‌های نام‌گذاری‌شده
        for filename in JUNK_FILES_ROOT:
            file_path = self.project_path / filename
            if file_path.exists() and file_path.is_file():
                size = file_path.stat().st_size
                self.results['junk_files'].append({
                    "file": filename,
                    "path": str(file_path),
                    "size": size,
                    "size_human": self._human_size(size),
                    "reason": "in JUNK_FILES_ROOT list",
                })
                self.results['summary']['total_space_reclaimable'] += size
                self.results['summary']['total_files_to_remove'] += 1

        # فایل‌های با الگو
        for item in self.project_path.iterdir():
            if not item.is_file():
                continue
            if item.name in JUNK_FILES_ROOT:
                continue  # قبلاً اضافه شده
            if self._matches_any_pattern(item.name, JUNK_FILE_PATTERNS):
                size = item.stat().st_size
                self.results['junk_files'].append({
                    "file": item.name,
                    "path": str(item),
                    "size": size,
                    "size_human": self._human_size(size),
                    "reason": "matches junk pattern",
                })
                self.results['summary']['total_space_reclaimable'] += size
                self.results['summary']['total_files_to_remove'] += 1

        # نمایش
        if self.results['junk_files']:
            print(f"  {Color.YELLOW}تعداد: {len(self.results['junk_files'])} فایل{Color.RESET}")
            for item in self.results['junk_files']:
                print(f"    {Color.RED}✗{Color.RESET} {item['size_human']:>12}  {item['file']}")
        else:
            print(f"  {Color.GREEN}✓ فایل غیرضروری در ریشه یافت نشد.{Color.RESET}")

    # ============================================================
    #  فاز ۲: شناسایی اسکریپت‌های پراکنده
    # ============================================================
    def find_scripts_to_move(self):
        print(f"\n{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}  ۲. اسکریپت‌های پراکنده (انتقال به scripts/){Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")

        for item in self.project_path.iterdir():
            if not item.is_file():
                continue
            should_move = False
            reason = ""

            if item.name in SCRIPTS_TO_MOVE:
                should_move = True
                reason = "in SCRIPTS_TO_MOVE list"
            elif self._matches_any_pattern(item.name, SCRIPTS_TO_MOVE_PATTERNS):
                should_move = True
                reason = "matches script pattern"

            if should_move:
                size = item.stat().st_size
                self.results['scripts_to_move'].append({
                    "file": item.name,
                    "path": str(item),
                    "destination": str(self.project_path / 'scripts' / item.name),
                    "size": size,
                    "size_human": self._human_size(size),
                    "reason": reason,
                })
                self.results['summary']['total_files_to_move'] += 1

        # نمایش
        if self.results['scripts_to_move']:
            print(f"  {Color.YELLOW}تعداد: {len(self.results['scripts_to_move'])} اسکریپت{Color.RESET}")
            for item in self.results['scripts_to_move']:
                print(f"    {Color.BLUE}→{Color.RESET} {item['size_human']:>12}  {item['file']}")
        else:
            print(f"  {Color.GREEN}✓ اسکریپت پراکنده‌ای یافت نشد.{Color.RESET}")

    # ============================================================
    #  فاز ۳: شناسایی پوشه‌های پشتیبان
    # ============================================================
    def find_backup_dirs(self):
        print(f"\n{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}  ۳. پوشه‌های پشتیبان و آرشیو{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'='*60}{Color.RESET}")

        for item in self.project_path.iterdir():
            if not item.is_dir():
                continue
            is_backup = False
            reason = ""

            if item.name in BACKUP_DIRS:
                is_backup = True
                reason = "in BACKUP_DIRS list"
            elif self._matches_any_pattern(item.name, BACKUP_DIR_PATTERNS):
                is_backup = True
                reason = "matches backup pattern"

            if is_backup:
                # محاسبه حجم پوشه
                dir_size = 0
                file_count = 0
                try:
                    for root, dirs, files in os.walk(item):
                        dirs[:] = [d for d in dirs if d not in SKIP_DIRS]
                        for f in files:
                            try:
                                dir_size += (Path(root) / f).stat().st_size
                                file_count += 1
                            except:
                                pass
                except:
                    pass

                self.results['backup_dirs'].append({
                    "dir": item.name,
                    "path": str(item),
                    "size": dir_size,
                    "size_human": self._human_size(dir_size),
                    "file_count": file_count,
                    "reason": reason,
                })
                self.results['summary']['total_space_reclaimable'] += dir_size
                self.results['summary']['total_dirs_to_remove'] += 1

        # نمایش
        if self.results['backup_dirs']:
            print(f"  {Color.YELLOW}تعداد: {len(self.results['backup_dirs'])} پوشه{Color.RESET}")
            for item in self.results['backup_dirs']:
                print(f"    {Color.RED}✗{Color.RESET} {item['size_human']:>12}  {item['dir']}/  ({item['file_count']} فایل)")
        else:
            print(f"  {Color.GREEN}✓ پوشه پشتیبانی یافت نشد.{Color.RESET}")

    # ============================================================
    #  فاز ۴: شناسایی پوشه‌های محیط مجازی
    # ============================================================
