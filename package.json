{
  "name": "econojin-monorepo",
  "private": true,
  "packageManager": "pnpm@8.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "pnpm install",
    "dev:web": "pnpm --filter @econojin/web dev",
    "dev:cms": "pnpm --filter @econojin/cms develop",
    "dev:admin": "pnpm --filter @econojin/admin dev",
    "build": "pnpm --filter @econojin/web build",
    "lint": "pnpm --filter @econojin/web lint",
    "type-check": "pnpm --filter @econojin/web type-check",
    "test": "pnpm --filter @econojin/web test",
    "test:e2e": "pnpm --filter @econojin/web test:e2e",
    "format": "pnpm --filter @econojin/web format"
  },
  "devDependencies": {
    "turbo": "^1.9.0",
    "pnpm": "^8.8.0"
  }
}
