# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=sqlite+aiosqlite:///./apps/econojin.db

# ==========================================
# Security
# ==========================================
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# LLM Provider Configuration
# ==========================================
# انتخاب provider: groq | gemini | openrouter | ollama | fake
LLM_PROVIDER=groq

# انتخاب مدل (اختیاری - اگر خالی باشد، از پیش‌فرض provider استفاده می‌شود)
LLM_MODEL=

# ==========================================
# LLM API Keys (حداقل یکی را تنظیم کنید)
# ==========================================

# Groq (توصیه‌شده - سریع‌ترین)
# ثبت‌نام رایگان: https://console.groq.com
GROQ_API_KEY=

# Google Gemini (کیفیت بالا)
# ثبت‌نام رایگان: https://aistudio.google.com
GOOGLE_API_KEY=

# OpenRouter (تنوع مدل‌ها)
# ثبت‌نام رایگان: https://openrouter.ai
OPENROUTER_API_KEY=

# Ollama (محلی - بدون نیاز به API Key)
# نصب: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# ==========================================
# Strapi CMS
# ==========================================
PUBLIC_URL=http://localhost:1337
STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337
ADMIN_JWT_SECRET=change-me-in-production
STRAPI_TOKEN=change-me-in-production

# ==========================================
# Supabase / Frontend
# ===========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# ==========================================
# Application
# ==========================================
APP_URL=http://localhost:8000
DEBUG=true