# ============================================================
# Econojin - Environment Configuration
# ============================================================
# Adapted from fastapi/full-stack-fastapi-template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control!
# ============================================================

# ── Application ──────────────────────────────────────────────
PROJECT_NAME=Econojin API
ENVIRONMENT=local                  # local | staging | production
DEBUG=true
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── API Configuration ───────────────────────────────────────
API_V1_STR=/api/v1
HOST=0.0.0.0
PORT=8000
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# ── Database ────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite+aiosqlite:///./apps/econojin.db

# PostgreSQL (production) - uncomment and configure:
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=changethis
# POSTGRES_DB=econojin
# DATABASE_URL=postgresql+asyncpg://postgres:changethis@localhost:5432/econojin

# ── Security ────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520   # 8 days (60 * 24 * 8)
REQUIRE_AUTH_FOR_WRITES=false       # Set to true in production

# ── Superuser (initial setup) ───────────────────────────────
FIRST_SUPERUSER=admin@econojin.com
FIRST_SUPERUSER_PASSWORD=changethis

# ── LLM / AI Provider ───────────────────────────────────────
# Options: groq | gemini | openrouter | ollama | fake
LLM_PROVIDER=fake
LLM_MODEL=

# Groq (recommended - fastest)
# Sign up: https://console.groq.com
GROQ_API_KEY=

# Google Gemini (high quality)
# Sign up: https://aistudio.google.com
GOOGLE_API_KEY=

# OpenRouter (model variety)
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# Ollama (local - no API key needed)
# Install: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# ── SMS Provider ────────────────────────────────────────────
# Options: kavenegar | twilio | mock
SMS_PROVIDER=mock
OTP_DEV_MODE=true

# Kavenegar (Iran)
KAVENEGAR_API_KEY=

# Twilio (International)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Email (SMTP) ────────────────────────────────────────────
SMTP_TLS=true
SMTP_SSL=false
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@econojin.com
EMAILS_FROM_NAME=Econojin
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48
EMAIL_TEST_USER=test@example.com

# ── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=                             # Sentry.io DSN for error tracking
SENTRY_TRACES_RATE=0.1                 # Performance tracing sample rate (0.0-1.0)
SENTRY_PROFILES_RATE=0.1               # Profiling sample rate (0.0-1.0)
APP_VERSION=1.0.0                    # Application version for release tracking

# ── Feature Flags ───────────────────────────────────────────
ENABLE_OTP=true
ENABLE_SIMULATION=true
ENABLE_ECOCOIN=true
ENABLE_GIS=true

# ── Strapi CMS ──────────────────────────────────────────────
PUBLIC_URL=http://localhost:1337
STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337
ADMIN_JWT_SECRET=change-me-in-production
STRAPI_TOKEN=change-me-in-production

# ── Supabase (optional) ─────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# ── Application URL ─────────────────────────────────────────
APP_URL=http://localhost:8000