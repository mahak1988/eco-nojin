"""
حذف فایل‌های استفاده‌نشده بر اساس MERGE_PLAN.json
"""

import sys
from pathlib import Path
import json


def cleanup():
    """حذف فایل‌های استفاده‌نشده."""
    project_root = Path(__file__).parent.parent
    
    print("=" * 70)
    print("🧹 پاکسازی فایل‌های استفاده‌نشده")
    print("=" * 70)
    
    # خواندن MERGE_PLAN.json
    merge_plan_file = project_root / 'MERGE_PLAN.json'
    
    if not merge_plan_file.exists():
        print(f"❌ {merge_plan_file} وجود ندارد")
        print("لطفاً ابتدا python -m apps.analyze_dependencies را اجرا کنید")
        return
    
    with open(merge_plan_file, 'r', encoding='utf-8') as f:
        merge_plan = json.load(f)
    
    unused_files = merge_plan.get('unused_files', [])
    
    print(f"\n📊 تعداد فایل‌های استفاده‌نشده: {len(unused_files)}")
    
    # لیست سیاه (فایل‌هایی که نباید حذف شوند)
    blacklist = {
        'analyze_dependencies.py',
        'analyze_project.py',
        'check_api_app_usage.py',
        'compare_main_files.py',
        'inspect_api_router.py',
        'cleanup_unused.py',
        'test_',
        'conftest.py',
        '__init__.py',
        'main.py',
    }
    
    # فیلتر کردن فایل‌ها
    files_to_delete = []
    
    for file_path in unused_files:
        file_name = Path(file_path).name
        
        # بررسی blacklist
        if any(bl in file_name for bl in blacklist):
            print(f"  ⏭️  {file_path} (در blacklist)")
            continue
        
        # بررسی وجود فایل
        full_path = project_root / file_path
        
        if not full_path.exists():
            print(f"  ⏭️  {file_path} (وجود ندارد)")
            continue
        
        files_to_delete.append(full_path)
    
    print(f"\n🗑️  تعداد فایل‌های قابل حذف: {len(files_to_delete)}")
    
    # تأیید
    if not files_to_delete:
        print("\n✅ هیچ فایلی برای حذف وجود ندارد")
        return
    
    print("\n⚠️  فایل‌هایی که حذف خواهند شد:")
    for file_path in files_to_delete[:20]:
        print(f"  • {file_path.relative_to(project_root)}")
    
    if len(files_to_delete) > 20:
        print(f"  ... و {len(files_to_delete) - 20} فایل دیگر")
    
    # پرسش تأیید
    response = input("\n❓ آیا مطمئن هستید؟ (yes/no): ")
    
    if response.lower() != 'yes':
        print("\n❌ عملیات لغو شد")
        return
    
    # حذف فایل‌ها
    deleted_count = 0
    
    for file_path in files_to_delete:
        try:
            file_path.unlink()
            deleted_count += 1
            print(f"  ✅ حذف شد: {file_path.relative_to(project_root)}")
        except Exception as e:
            print(f"  ❌ خطا در حذف {file_path}: {e}")
    
    print(f"\n{'=' * 70}")
    print(f"✅ {deleted_count} فایل حذف شد")
    print(f"{'=' * 70}")


if __name__ == "__main__":
    cleanup()