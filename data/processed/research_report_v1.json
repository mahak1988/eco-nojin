{
  "metadata": {
    "title": "Economugin: Integrated Assessment of Dryland Restoration",
    "authors": [
      "Research Team"
    ],
    "affiliation": "Hydromanugin Project",
    "date": "2026-05-27T14:20:05.363295",
    "version": "1.0.0",
    "doi": "10.5281/zenodo.economugin.v1"
  },
  "abstract": "This study presents an integrated modeling framework for assessing dryland restoration strategies using coupled hydrological, agricultural, and soil carbon models. The Economugin platform enables scenario analysis, uncertainty quantification, and decision support for sustainable land management in semi-arid regions.",
  "methods": {
    "models_coupled": [
      "SWAT+ (hydrology)",
      "AquaCrop (yield)",
      "RothC (soil carbon)"
    ],
    "data_sources": [
      "ERA5-Land (climate)",
      "Sentinel-2 (imagery)",
      "Field measurements"
    ],
    "spatial_resolution": "1 km grid",
    "temporal_resolution": "daily (climate), annual (models)",
    "study_area": {
      "bbox": [
        51.2,
        35.5,
        51.3,
        35.6
      ],
      "area_ha": 1000,
      "region": "Central Iran pilot"
    }
  },
  "scenarios": [
    {
      "id": "S0",
      "name": "Baseline",
      "description": "Current management practices"
    },
    {
      "id": "S1",
      "name": "Conservation Agriculture",
      "description": "Reduced tillage + residue retention"
    },
    {
      "id": "S2",
      "name": "Irrigation Optimization",
      "description": "Drip irrigation + scheduling"
    },
    {
      "id": "S3",
      "name": "Integrated",
      "description": "S1 + S2 + cover crops"
    }
  ],
  "results_summary": {
    "yield_change_pct": {
      "S1": 8.5,
      "S2": 15.2,
      "S3": 22.1
    },
    "soc_change_t_ha_10yr": {
      "S1": 0.8,
      "S2": 0.3,
      "S3": 1.4
    },
    "water_use_efficiency": {
      "S1": 1.9,
      "S2": 2.4,
      "S3": 2.8
    }
  },
  "uncertainty": {
    "method": "Monte Carlo (n=1000)",
    "parameters_varied": [
      "precipitation ±15%",
      "soil_params ±20%",
      "model_coeffs ±10%"
    ],
    "output_ci_95": {
      "yield_kg_ha": {
        "mean": 3200,
        "lower": 2850,
        "upper": 3580
      },
      "soc_change_t_ha": {
        "mean": 1.1,
        "lower": 0.6,
        "upper": 1.7
      }
    }
  },
  "conclusions": [
    "Integrated management (S3) maximizes yield (+22%) and soil carbon (+1.4 t/ha)",
    "Uncertainty analysis shows robust benefits across parameter ranges",
    "Platform enables scalable decision support for dryland restoration"
  ],
  "data_availability": "All code and synthetic data available at: https://github.com/economugin/economugin"
}