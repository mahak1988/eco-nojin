# Exchange (🔴 محافظت شده با Row-Level Lock و محاسبات Decimal)
# =========================================================================
@router.post("/exchange", response_model=Dict[str, Any])
async def exchange_tokens(
    data: ExchangeRequest, 
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    stmt = select(EcoUserWallet).where(
        (EcoUserWallet.id == data.wallet_id) & (EcoUserWallet.user_id == current_user.id)
    ).with_for_update()
    
    result = await db.execute(stmt)
    wallet = result.scalar_one_or_none()
    
    if not wallet:
        raise HTTPException(status_code=404, detail="Wallet not found or access denied")

    result_rate = await db.execute(
        select(EcoExchangeRate).where(
            (EcoExchangeRate.from_token == data.from_token) &
            (EcoExchangeRate.to_token == data.to_token) &
            (EcoExchangeRate.is_active == True)
        )
    )
    rate = result_rate.scalar_one_or_none()
    if not rate:
        raise HTTPException(status_code=404, detail="Exchange rate not found or inactive")

    if data.amount < rate.min_amount or data.amount > rate.max_amount:
        raise HTTPException(status_code=400, detail=f"Amount must be between {rate.min_amount} and {rate.max_amount}")

    # 🔴 محاسبات دقیق مالی با Decimal
    amount_dec = Decimal(str(data.amount))
    fee_percent_dec = Decimal(str(rate.fee_percent))
    rate_dec = Decimal(str(rate.rate))
    
