# api/modules/ecocoin/router.py
"""
ماژول مدیریت توکن اکویی (EcoCoin) - نسخه مالی امن
نسخه 2.0 - محافظت شده در برابر Race Condition و خطاهای محاسباتی
"""
from api.core.schemas import SuccessResponse, IDResponse, StatsResponse, PaginatedResponse
from fastapi import APIRouter, HTTPException, Depends, status
from pydantic import BaseModel
from typing import Dict, Any, List, Optional
from datetime import datetime, timedelta
from decimal import Decimal
from sqlalchemy import select, func, desc
from sqlalchemy.ext.asyncio import AsyncSession
import secrets
import hashlib

from api.core.database import get_db
from api.core.security import get_current_user # 🔴 احراز هویت اجباری
from api.modules.library.models import User # 🔴 مدل کاربر برای بررسی مالکیت
from api.modules.ecocoin.models import (
    EcoToken, EcoUserWallet, EcoTx, EcoAction, EcoReward,
    EcoStaking, EcoRewardRate, EcoExchangeRate,
    TokenType, TxType, EcoActionType, RewardStatus, TxStatus
)

class TransferResponse(BaseModel):
    """Auto-generated response model for transfer_tokens"""
    tx_hash: str
    status: str
    new_balance: int = 0




class UserWalletResponse(BaseModel):
    """User wallet information"""
    wallet_address: str
    eco_balance: int = 0
    grc_balance: int = 0
    staked_eco: int = 0
    staked_grc: int = 0
    total_earned: int = 0
    user_level: int = 1
    reputation_score: float = 0.0



class EcoCoinStatsResponse(BaseModel):
    """Auto-generated response model for /stats"""
    wallets_count: int = 0
    total_rewards: int = 0
    actions_count: int = 0
    carbon_sequestered_tons: float = 0.0
    water_saved_liters: float = 0.0
    energy_generated_kwh: float = 0.0




# ============================================================
# Additional Endpoints (Auto-generated)
# ============================================================




# =========================================================================
# Pydantic Models
# =========================================================================
class WalletCreate(BaseModel):
    user_id: int

class TransferRequest(BaseModel):
    to_address: str
    token_symbol: str
    amount: int
    description: Optional[str] = None

class EcologicalActionCreate(BaseModel):
    action_type: str
    title: str
    description: Optional[str] = None
    quantity: float
    unit: str
    latitude: Optional[float] = None
    longitude: Optional[float] = None
    location_name: Optional[str] = None
    evidence_urls: Optional[List[str]] = []

class StakeRequest(BaseModel):
    token_symbol: str
    amount: int
    lock_period_days: int = 30

class ExchangeRequest(BaseModel):
    from_token: str
    to_token: str
    amount: int


# =========================================================================
# Helpers
# =========================================================================
def gen_wallet_address() -> str:
    return "0x" + secrets.token_hex(20)

def gen_tx_hash() -> str:
    ts = datetime.now().isoformat()
    rnd = secrets.token_hex(16)
    return "0x" + hashlib.sha256(f"{ts}{rnd}".encode()).hexdigest()[:64]


# =========================================================================
# Wallets
# =========================================================================
@router.post("/wallets", response_model=Dict[str, Any])
async def create_wallet(data: WalletCreate, db: AsyncSession = Depends(get_db)):
    result = await db.execute(select(EcoUserWallet).where(EcoUserWallet.user_id == data.user_id))
    if result.scalar_one_or_none():
        raise HTTPException(status_code=400, detail="Wallet already exists for this user")

    wallet = EcoUserWallet(
        user_id=data.user_id,
        wallet_address=gen_wallet_address(),
    )
    db.add(wallet)
    await db.commit()
    await db.refresh(wallet)
    return {"id": wallet.id, "wallet_address": wallet.wallet_address, "status": "created"}


@router.get("/wallets/me", response_model=UserWalletResponse)
async def get_my_wallet(
    current_user: User = Depends(get_current_user), # 🔴 فقط کیف پول کاربر لاگین کرده
    db: AsyncSession = Depends(get_db)
):
    result = await db.execute(select(EcoUserWallet).where(EcoUserWallet.user_id == current_user.id))
    wallet = result.scalar_one_or_none()
    if not wallet:
        raise HTTPException(status_code=404, detail="Wallet not found. Please create one first.")
    
    return {
        "wallet": {
            "id": wallet.id,
            "wallet_address": wallet.wallet_address,
            "eco_balance": wallet.eco_balance,
            "grc_balance": wallet.grc_balance,
            "staked_eco": wallet.staked_eco,
            "staked_grc": wallet.staked_grc,
            "total_earned": wallet.total_earned,
            "user_level": wallet.user_level,
            "reputation_score": wallet.reputation_score,
        }
    }


# =========================================================================
# Transfers (🔴 محافظت شده با Row-Level Lock)
# =========================================================================
@router.post("/transfer", response_model=Dict[str, Any])
async def transfer_tokens(
    data: TransferRequest, 
    current_user: User = Depends(get_current_user), # 🔴 احراز هویت
    db: AsyncSession = Depends(get_db)
):
    # 🔴 حیاتی: with_for_update() ردیف را قفل می‌کند تا از Race Condition جلوگیری شود
    stmt = select(EcoUserWallet).where(
        (EcoUserWallet.id == data.from_wallet_id) & (EcoUserWallet.user_id == current_user.id)
    ).with_for_update()
    
    result = await db.execute(stmt)
    from_wallet = result.scalar_one_or_none()
    
    if not from_wallet:
        raise HTTPException(status_code=404, detail="Source wallet not found or access denied")
    if from_wallet.is_frozen:
        raise HTTPException(status_code=403, detail="Wallet is frozen")

    # بررسی موجودی و کسر
    if data.token_symbol == "ECO":
        if from_wallet.eco_balance < data.amount:
            raise HTTPException(status_code=400, detail="Insufficient ECO balance")
        from_wallet.eco_balance -= data.amount
        from_wallet.total_spent += data.amount
    elif data.token_symbol == "GRC":
        if from_wallet.grc_balance < data.amount:
            raise HTTPException(status_code=400, detail="Insufficient GRC balance")
        from_wallet.grc_balance -= data.amount
        from_wallet.total_spent += data.amount
    else:
        raise HTTPException(status_code=400, detail="Invalid token symbol")

    # یافتن یا ساخت کیف پول مقصد
    result_to = await db.execute(select(EcoUserWallet).where(EcoUserWallet.wallet_address == data.to_address))
    to_wallet = result_to.scalar_one_or_none()
    
    if not to_wallet:
        to_wallet = EcoUserWallet(user_id=0, wallet_address=data.to_address) # 0 برای آدرس‌های خارجی
        db.add(to_wallet)
        await db.flush() # دریافت ID قبل از کامیت نهایی

    if data.token_symbol == "ECO":
        to_wallet.eco_balance += data.amount
    else:
        to_wallet.grc_balance += data.amount

    # ثبت تراکنش
    tx = EcoTx(
        tx_hash=gen_tx_hash(),
        wallet_id=from_wallet.id,
        token_symbol=data.token_symbol,
        tx_type=TxType.TRANSFER,
        amount=data.amount,
        from_address=from_wallet.wallet_address,
        to_address=data.to_address,
        status=TxStatus.CONFIRMED,
        description=data.description,
        confirmed_at=datetime.now(),
    )
    db.add(tx)
    await db.commit()

    return {
        "tx_hash": tx.tx_hash,
        "status": "confirmed",
        "new_balance": from_wallet.eco_balance if data.token_symbol == "ECO" else from_wallet.grc_balance,
    }


# =========================================================================
# Ecological Actions & Verification
# =========================================================================
@router.post("/actions", response_model=Dict[str, Any])
async def submit_action(
    data: EcologicalActionCreate, 
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    result = await db.execute(
        select(EcoRewardRate).where(
            (EcoRewardRate.action_type == EcoActionType(data.action_type)) & 
            (EcoRewardRate.is_active == True)
        )
    )
    rate = result.scalar_one_or_none()
    if not rate:
        raise HTTPException(status_code=404, detail="Reward rate not defined or inactive for this action")

    # 🔴 محاسبه دقیق با Decimal
    eco_reward = int(Decimal(str(data.quantity)) * Decimal(str(rate.eco_per_unit)) * Decimal(str(rate.bonus_multiplier)))
    grc_reward = int(Decimal(str(data.quantity)) * Decimal(str(rate.grc_per_unit)) * Decimal(str(rate.bonus_multiplier)))

    action = EcoAction(
        user_id=current_user.id, # 🔴 استفاده از ID کاربر احراز هویت شده
        action_type=EcoActionType(data.action_type),
        title=data.title,
        description=data.description,
        quantity=data.quantity,
        unit=data.unit,
        latitude=data.latitude,
        longitude=data.longitude,
        location_name=data.location_name,
        evidence_urls=data.evidence_urls,
        eco_reward=eco_reward,
        grc_reward=grc_reward,
        carbon_sequestered=float(Decimal(str(rate.carbon_per_unit)) * Decimal(str(data.quantity))),
        water_saved=float(Decimal(str(rate.water_per_unit)) * Decimal(str(data.quantity))),
        energy_generated=float(Decimal(str(rate.energy_per_unit)) * Decimal(str(data.quantity))),
        status=RewardStatus.PENDING,
    )
    db.add(action)
    await db.commit()
    await db.refresh(action)

    return {
        "id": action.id,
        "eco_reward": eco_reward,
        "grc_reward": grc_reward,
        "status": "pending_verification",
    }


@router.post("/actions/{action_id}/verify", response_model=IDResponse)
async def verify_action(
    action_id: int, 
    approved: bool = True, 
    current_user: User = Depends(get_current_user), # در واقعیت باید چک شود current_user.role == REVIEWER
    db: AsyncSession = Depends(get_db)
):
    # 🔴 قفل کردن اکشن برای جلوگیری از تایید همزمان
    stmt = select(EcoAction).where(EcoAction.id == action_id).with_for_update()
    result = await db.execute(stmt)
    action = result.scalar_one_or_none()
    
    if not action:
        raise HTTPException(status_code=404, detail="Action not found")
    if action.status != RewardStatus.PENDING:
        raise HTTPException(status_code=400, detail=f"Action already reviewed (Status: {action.status.value})")

    if approved:
        action.status = RewardStatus.APPROVED
        action.verified_by = current_user.id
        action.verified_at = datetime.now()

        # 🔴 قفل کردن کیف پول برای واریز ایمن
        wallet_stmt = select(EcoUserWallet).where(EcoUserWallet.user_id == action.user_id).with_for_update()
        wallet_result = await db.execute(wallet_stmt)
        wallet = wallet_result.scalar_one_or_none()
        
        if not wallet:
            raise HTTPException(status_code=404, detail="User wallet not found")

        wallet.eco_balance += action.eco_reward
        wallet.grc_balance += action.grc_reward
        wallet.total_earned += (action.eco_reward + action.grc_reward)

        tx = EcoTx(
            tx_hash=gen_tx_hash(),
            wallet_id=wallet.id,
            token_symbol="ECO",
            tx_type=TxType.REWARD,
            amount=action.eco_reward,
            from_address="ecocoin_system",
            to_address=wallet.wallet_address,
            status=TxStatus.CONFIRMED,
            description=f"Ecological reward: {action.title}",
            confirmed_at=datetime.now(),
        )
        db.add(tx)

        reward = EcoReward(
            action_id=action.id,
            wallet_id=wallet.id,
            eco_amount=action.eco_reward,
            grc_amount=action.grc_reward,
            base_reward=action.eco_reward,
            total_reward=action.eco_reward + action.grc_reward,
            status="paid",
            paid_at=datetime.now(),
        )
        db.add(reward)
        await db.commit()

        return {"status": "approved", "eco_paid": action.eco_reward, "grc_paid": action.grc_reward}
    else:
        action.status = RewardStatus.REJECTED
        action.verified_by = current_user.id
        action.verified_at = datetime.now()
        await db.commit()
        return {"status": "rejected"}


# =========================================================================
# Staking (🔴 محافظت شده با Row-Level Lock)
# =========================================================================
@router.post("/stake", response_model=Dict[str, Any])
async def stake_tokens(
    data: StakeRequest, 
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    stmt = select(EcoUserWallet).where(
        (EcoUserWallet.id == data.wallet_id) & (EcoUserWallet.user_id == current_user.id)
    ).with_for_update()
    
    result = await db.execute(stmt)
    wallet = result.scalar_one_or_none()
    
    if not wallet:
        raise HTTPException(status_code=404, detail="Wallet not found or access denied")

    if data.token_symbol == "ECO":
        if wallet.eco_balance < data.amount:
            raise HTTPException(status_code=400, detail="Insufficient ECO balance")
        wallet.eco_balance -= data.amount
        wallet.staked_eco += data.amount
    elif data.token_symbol == "GRC":
        if wallet.grc_balance < data.amount:
            raise HTTPException(status_code=400, detail="Insufficient GRC balance")
        wallet.grc_balance -= data.amount
        wallet.staked_grc += data.amount
    else:
        raise HTTPException(status_code=400, detail="Invalid token symbol")

    staking = EcoStaking(
        wallet_id=wallet.id,
        token_symbol=data.token_symbol,
        amount=data.amount,
        lock_period_days=data.lock_period_days,
        end_date=datetime.now() + timedelta(days=data.lock_period_days),
        apy=Decimal('10.0') if data.token_symbol == "ECO" else Decimal('15.0'), # 🔴 استفاده از Decimal
    )
    db.add(staking)
    await db.commit()

    return {"staking_id": staking.id, "amount": data.amount, "apy": float(staking.apy)}


